<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <!-- ============================= -->
    <!-- Properties -->
    <!-- ============================= -->
    <property name="CONSOLE_LOG_PATTERN"
              value="%clr(%d{yyyy-MM-dd HH:mm:ss.SSS}){faint} %clr(${LOG_LEVEL_PATTERN:-%5p}) %clr([%15.15t]){faint} %clr(%-40.40logger{39}){cyan} %clr(:){faint} %m%n${LOG_EXCEPTION_CONVERSION_WORD:-%wEx}"/>

    <property name="REQUEST_LOG_FILE" value="logs/request-events.json"/>
    <property name="BUSINESS_LOG_FILE" value="logs/business-events.json"/>
    <property name="SYSTEM_LOG_FILE" value="logs/system-events.json"/>

    <!-- ============================= -->
    <!-- Console Appender (Dev Only) -->
    <!-- ============================= -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${CONSOLE_LOG_PATTERN}</pattern>
            <charset>utf8</charset>
        </encoder>
    </appender>

    <!-- ============================= -->
    <!-- REQUEST JSON Appender -->
    <!-- ============================= -->
    <appender name="REQUEST_JSON" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${REQUEST_LOG_FILE}</file>

        <encoder class="net.logstash.logback.encoder.LoggingEventCompositeJsonEncoder">
            <providers>
                <timestamp><fieldName>@timestamp</fieldName></timestamp>
                <logLevel><fieldName>log.level</fieldName></logLevel>
                <loggerName><fieldName>logger_name</fieldName></loggerName>
                <threadName><fieldName>thread_name</fieldName></threadName>
                <arguments/>
                <mdc/>
                <stackTrace/>
                <pattern>
                    <pattern>
                        {
                          "application": "ecommerce-log-generator",
                          "environment": "development"
                        }
                    </pattern>
                </pattern>
            </providers>
        </encoder>

        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/request-events-%d{yyyy-MM-dd}.json</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
    </appender>

    <!-- ============================= -->
    <!-- BUSINESS JSON Appender -->
    <!-- ============================= -->
    <appender name="BUSINESS_JSON" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${BUSINESS_LOG_FILE}</file>

        <encoder class="net.logstash.logback.encoder.LoggingEventCompositeJsonEncoder">
            <providers>
                <timestamp><fieldName>@timestamp</fieldName></timestamp>
                <logLevel><fieldName>log.level</fieldName></logLevel>
                <loggerName><fieldName>logger_name</fieldName></loggerName>
                <threadName><fieldName>thread_name</fieldName></threadName>
                <arguments/>
                <mdc/>
                <stackTrace/>
                <pattern>
                    <pattern>
                        {
                          "application": "ecommerce-log-generator",
                          "environment": "development"
                        }
                    </pattern>
                </pattern>
            </providers>
        </encoder>

        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/business-events-%d{yyyy-MM-dd}.json</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
    </appender>

    <!-- ============================= -->
    <!-- SYSTEM JSON Appender -->
    <!-- ============================= -->
    <appender name="SYSTEM_JSON" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${SYSTEM_LOG_FILE}</file>

        <encoder class="net.logstash.logback.encoder.LoggingEventCompositeJsonEncoder">
            <providers>
                <timestamp><fieldName>@timestamp</fieldName></timestamp>
                <logLevel><fieldName>log.level</fieldName></logLevel>
                <loggerName><fieldName>logger_name</fieldName></loggerName>
                <threadName><fieldName>thread_name</fieldName></threadName>
                <arguments/>
                <mdc/>
                <stackTrace/>
                <pattern>
                    <pattern>
                        {
                          "application": "ecommerce-log-generator",
                          "environment": "development"
                        }
                    </pattern>
                </pattern>
            </providers>
        </encoder>

        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/system-events-%d{yyyy-MM-dd}.json</fileNamePattern>
            <maxHistory>30</maxHistory>
        </rollingPolicy>
    </appender>

    <!-- ============================= -->
    <!-- Async Wrappers -->
    <!-- ============================= -->
    <appender name="ASYNC_REQUEST" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>512</queueSize>
        <discardingThreshold>0</discardingThreshold>
        <appender-ref ref="REQUEST_JSON"/>
    </appender>

    <appender name="ASYNC_BUSINESS" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>512</queueSize>
        <discardingThreshold>0</discardingThreshold>
        <appender-ref ref="BUSINESS_JSON"/>
    </appender>

    <appender name="ASYNC_SYSTEM" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>512</queueSize>
        <discardingThreshold>0</discardingThreshold>
        <appender-ref ref="SYSTEM_JSON"/>
    </appender>

    <!-- ============================= -->
    <!-- Bind Custom Loggers -->
    <!-- ============================= -->
    <logger name="REQUEST_LOGGER" level="INFO" additivity="false">
        <appender-ref ref="ASYNC_REQUEST"/>
    </logger>

    <logger name="BUSINESS_LOGGER" level="INFO" additivity="false">
        <appender-ref ref="ASYNC_BUSINESS"/>
    </logger>

    <logger name="SYSTEM_LOGGER" level="ERROR" additivity="false">
        <appender-ref ref="ASYNC_SYSTEM"/>
    </logger>

    <!-- ============================= -->
    <!-- Spring Logs (Console Only) -->
    <!-- ============================= -->
    <logger name="org.springframework" level="INFO"/>

    <!-- ============================= -->
    <!-- Root -->
    <!-- ============================= -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>

</configuration>